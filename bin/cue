#!/usr/bin/env node
/**
 * Cue CLI - 自动触发版
 * 用法：cue [选项] [参数] 或直接输入研究问题
 */
import { handleCommand, detectResearchIntent } from '@cuebot/skill';
import { fileURLToPath } from 'url';
import path from 'path';

// 🔧 修复：自动检测 OpenClaw 会话信息并设置 CHAT_ID
function detectChatId() {
  // 1. 优先使用环境变量（支持所有渠道）
  const envVars = [
    'CHAT_ID',
    'OPENCLAW_SENDER_ID',
    'OPENCLAW_CHAT_ID',
    'FEISHU_OPENID',
    'FEISHU_CHAT_ID',
    'SENDER_ID',
    'OPENCLAW_TARGET',
    'TELEGRAM_CHAT_ID',
    'DISCORD_CHANNEL_ID',
    'WHATSAPP_CHAT_ID',
    'SLACK_CHANNEL_ID'
  ];
  
  for (const envVar of envVars) {
    if (process.env[envVar]) {
      // 清理常见前缀：user:, chat:, channel: 等
      return process.env[envVar].replace(/^(user:|chat:|channel:)/, '');
    }
  }
  
  // 2. 从 workspace 目录解析用户 ID（通用方案，支持所有渠道）
  try {
    const cwd = process.cwd();
    // 匹配：/workspaces/{channel}-{user_id}
    // 支持：feishu-ou_xxx, telegram-123456, discord-789012, etc.
    const match = cwd.match(/\/workspaces\/([a-zA-Z]+)-([a-zA-Z0-9_]+)/);
    if (match && match[2]) {
      // 返回用户 ID 部分（第二个捕获组）
      return match[2];
    }
  } catch (e) {
    // 忽略错误
  }
  
  return null;
}

const detectedChatId = detectChatId();
if (detectedChatId) {
  process.env.CHAT_ID = detectedChatId;
}

const args = process.argv.slice(2);
let command = args[0] || '';
let params = args.slice(1);

// 转换短选项
const optionMap = {
  '-t': 'ct',  // task
  '-m': 'cm',  // monitor
  '-n': 'cn',  // notification
  '-k': 'key', // key
  '-h': 'ch'   // help
};

// 🔍 自动触发检测逻辑
if (!command.startsWith('/') && !optionMap[command]) {
  // 不是 slash command，也不是短选项，尝试检测研究意图
  const rawInput = args.join(' ');
  
  if (rawInput) {
    // 调用 detectResearchIntent() 检测
    const intent = detectResearchIntent(rawInput);
    
    if (intent) {
      // 检测到研究意图，自动触发 /cue 命令
      console.log(`🎯 检测到研究意图，正在启动研究...`);
      command = 'cue';
      params = [intent.topic];
    } else {
      // 没有检测到研究意图，返回空结果让主 Agent 继续处理
      console.log('');
      process.exit(0);
    }
  } else {
    // 没有输入，显示帮助
    command = 'ch';
    params = [];
  }
} else {
  // 是 slash command 或短选项，按原方式处理
  
  // 如果是 slash command，去掉开头的 '/'
  if (command.startsWith('/')) {
    command = command.slice(1);
  }
  
  // 如果是短选项，转换为完整命令
  if (optionMap[command]) {
    command = optionMap[command];
  } else if (command && !command.startsWith('-')) {
    // 没有选项，默认是研究问题
    // command 保持不变，作为问题
    params = [command, ...params];
    command = 'cue';
  } else if (command === '-h' || !command) {
    command = 'ch';
    params = [];
  }
}

handleCommand(command, params).then(result => {
  console.log(result);
}).catch(err => {
  console.error('Error:', err.message);
  process.exit(1);
});
