#!/usr/bin/env node
/**
 * Cue CLI - 简洁版
 * 用法：cue [选项] [参数]
 */
import { handleCommand } from '@cuebot/skill';
import { fileURLToPath } from 'url';
import path from 'path';

// 🔧 修复：自动检测 OpenClaw 会话信息并设置 CHAT_ID
function detectChatId() {
  // 1. 优先使用环境变量
  const envVars = [
    'CHAT_ID',
    'OPENCLAW_SENDER_ID',
    'OPENCLAW_CHAT_ID',
    'FEISHU_OPENID',
    'FEISHU_CHAT_ID',
    'SENDER_ID',
    'OPENCLAW_TARGET'
  ];
  
  for (const envVar of envVars) {
    if (process.env[envVar]) {
      return process.env[envVar].replace(/^user:/, '');
    }
  }
  
  // 2. 从 workspace 目录解析用户 ID（使用当前工作目录）
  try {
    const cwd = process.cwd();
    // 匹配：/workspaces/feishu-ou_xxx 或 /workspaces/feishu-ou_xxx/
    const match = cwd.match(/\/workspaces\/feishu-([a-zA-Z0-9_]+)/);
    if (match && match[1]) {
      return match[1];
    }
  } catch (e) {
    // 忽略错误
  }
  
  return null;
}

const detectedChatId = detectChatId();
if (detectedChatId) {
  process.env.CHAT_ID = detectedChatId;
}

const args = process.argv.slice(2);
let command = args[0] || '';
let params = args.slice(1);

// 转换短选项
const optionMap = {
  '-t': 'ct',  // task
  '-m': 'cm',  // monitor
  '-n': 'cn',  // notification
  '-k': 'key', // key
  '-h': 'ch'   // help
};

// 如果是短选项，转换为完整命令
if (optionMap[command]) {
  command = optionMap[command];
} else if (command && !command.startsWith('-')) {
  // 没有选项，默认是研究问题
  // command 保持不变，作为问题
  params = [command, ...params];
  command = 'cue';
} else if (command === '-h' || !command) {
  command = 'ch';
  params = [];
}

handleCommand(command, params).then(result => {
  console.log(result);
}).catch(err => {
  console.error('Error:', err.message);
  process.exit(1);
});
